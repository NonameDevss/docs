                  "en/reference/endpoints"
                ]
              }
            ]
          }
        ]
      },
      {
        "language": "ru",
        "tabs": [
          {
            "tab": "Гайды",
            "groups": [
              {
                "group": "Быстрый старт",
                "pages": [
                  "ru/index",
                  "ru/guides/authentication",
                  "ru/guides/background-removal",
                  "ru/guides/payments"
                ]
              }
            ]
          },
          {
            "tab": "Справочник",
            "groups": [
              {
                "group": "API",
                "pages": [
                  "ru/reference/endpoints"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
